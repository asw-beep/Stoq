# Copy to .env and fill in real values. .env is gitignored.

# ---- Database ----
# For Docker Compose, host is the service name "db". For host-run backend, use localhost.
POSTGRES_USER=stockuser
POSTGRES_PASSWORD=stockpass
POSTGRES_DB=stockdb
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Full URL is derived from the parts above by core/config.py, but can be overridden:
# DATABASE_URL=postgresql+psycopg://stockuser:stockpass@db:5432/stockdb

# ---- Auth / JWT ----
SECRET_KEY=use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ALGORITHM=HS256

# ---- Market data ----
MARKET_DATA_PROVIDER=yfinance
SEED_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA
HISTORY_YEARS=5

# ---- News / sentiment ----
# Free key from https://finnhub.io — 60 req/min on the free tier.
FINNHUB_API_KEY=your-finnhub-key-here

# ---- App ----
ENVIRONMENT=development
LOG_LEVEL=INFO
